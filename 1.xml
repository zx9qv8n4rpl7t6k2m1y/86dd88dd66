<?xml version="1.0" encoding="UTF-8" ?>
<Module>
<ModulePrefs title="classroom" />
<Content type="html"><![CDATA[


<!DOCTYPE html>
<html lang="en-us">
<head>
<meta charset="utf-8"/>
<meta http-equiv="Content-Type" content="text/html; charset=utf-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no"/>
<style>
  canvas:focus { outline: none; }
  html, body {
    padding: 0; margin: 0; overflow: hidden;
    -webkit-touch-callout: none; -webkit-user-select: none;
    -khtml-user-select: none; -moz-user-select: none;
    -ms-user-select: none; user-select: none;
    -webkit-tap-highlight-color: rgba(0,0,0,0);
    height: 100%; background: #231f20;
  }
  #unity-container { position: fixed; left: 0; top: 0; width: 100%; height: 100%; }
  #unity-canvas    { width: 100%; height: 100%; }
  #loading-cover {
    position: fixed; left: 0; top: 0; width: 100%; height: 100%;
    background: #231f20; display: flex; align-items: center;
    justify-content: center; flex-direction: column; z-index: 10;
  }
  #unity-progress-bar-empty {
    width: 300px; height: 8px; border: 1px solid #555;
    border-radius: 4px; background: #111; display: none; margin-top: 16px;
  }
  #unity-progress-bar-full {
    height: 100%; background: #e8b400; border-radius: 3px;
    width: 0%; transition: width 0.2s;
  }
  .spinner {
    width: 44px; height: 44px;
    border: 4px solid #333; border-top: 4px solid #e8b400;
    border-radius: 50%; animation: spin 1s linear infinite;
  }
  @keyframes spin { to { transform: rotate(360deg); } }
  #loading-text { color: #888; font-family: sans-serif; font-size: 13px; margin-top: 10px; }
</style>
</head>
<body>

<div id="unity-container">
  <canvas id="unity-canvas" tabindex="-1"></canvas>
</div>
<div id="loading-cover">
  <div class="spinner"></div>
  <div id="unity-progress-bar-empty">
    <div id="unity-progress-bar-full"></div>
  </div>
  <div id="loading-text">Yukluyor...</div>
</div>

<script>
/* ============================================================
   CONFIG — GitHub CDN reponuza gore degistirin
   ============================================================ */
const CDN = "https://cdn.jsdelivr.net/gh/gulamen/86dd88dd66@main/Build";

const LOADER_URL    = CDN + "/83cbc69280df1032fc7206db435c9bb6.loader.js";
const FRAMEWORK_URL = CDN + "/332d115891b7bc45885dfd1db543bc96.framework.js.unityweb";
const CODE_URL      = CDN + "/64a3756e786780c55c83887ba94f46a0.wasm.unityweb";
const BG_URL        = CDN + "/832b10e5569d1a61353af716ecc93a65.jpg";
const DATA_FILE     = "d0a276550058e04f5e66c0561d0cef39.data.unityweb";
const DATA_PARTS    = 4;

/* ============================================================
   UI REFERANSLARi
   ============================================================ */
const canvas           = document.querySelector("#unity-canvas");
const loadingCover     = document.querySelector("#loading-cover");
const progressBarEmpty = document.querySelector("#unity-progress-bar-empty");
const progressBarFull  = document.querySelector("#unity-progress-bar-full");
const loadingText      = document.querySelector("#loading-text");

canvas.style.background = `url('${BG_URL}') center / cover`;
document.addEventListener('contextmenu', e => e.preventDefault());
function focusGame() { canvas.focus(); }
window.addEventListener('pointerdown', focusGame);
window.addEventListener('touchstart',  focusGame);

/* ============================================================
   DATA.UNITYWEB PART YUKLEME + BLOB URL
   ============================================================ */
async function assembleDataBlob() {
  const parts = [];
  for (let i = 0; i < DATA_PARTS; i++) {
    loadingText.textContent = `Classroom Central Unblocked Sites!... (${i + 1}/${DATA_PARTS})`;
    const r = await fetch(`${CDN}/${DATA_FILE}.part${i}`);
    if (!r.ok) throw new Error(`Part ${i} aaa: ${r.status}`);
    parts.push(new Uint8Array(await r.arrayBuffer()));
  }
  loadingText.textContent = "aaa...";
  const total  = parts.reduce((s, p) => s + p.length, 0);
  const merged = new Uint8Array(total);
  let off = 0;
  for (const p of parts) { merged.set(p, off); off += p.length; }
  return URL.createObjectURL(new Blob([merged], { type: 'application/octet-stream' }));
}

/* ============================================================
   YANDEX SDK STUBLARI
   Orijinal fonksiyon isimleri korundu — Unity jslib bunlari cagirir
   Dil: English (0) — Yandex olmadigi icin varsayilan
   ============================================================ */
window.unityInstance = null;

/* --- checkSave: Unity Start() -> jslib -> bu fonksiyon --- */
function checkSave() {
  loadData();
  /* payments yok, initPurchasing/checkShop atlaniyor */
  checkLanguage();
}

/* --- gameReady --- */
function gameReady() {
  console.log('[gameReady] called');
  /* LoadingAPI yok, no-op */
}

/* --- Gameplay events --- */
function startEvent() { console.log('[startEvent]'); }
function stopEvent()  { console.log('[stopEvent]');  }

/* --- Dil: English = 0 --- */
function checkLanguage() {
  console.log('[checkLanguage] => English (0)');
  if (window.unityInstance)
    window.unityInstance.SendMessage('SDKPlatform', 'SetLanguage', 0);
}

/* --- Bolge: 0 = diger --- */
function checkCom() {
  console.log('[checkCom] => 0');
  if (window.unityInstance)
    window.unityInstance.SendMessage('SDKPlatform', 'IsCom', 0);
}

/* --- Cloud load: kayit yok, bos string --- */
function loadData() {
  console.log('[loadData] No player — sending empty save');
  if (window.unityInstance) {
    window.unityInstance.SendMessage('SDKPlatform', 'LoadCloud', '');
  }
}

/* --- Cloud save: kayit desteklenmiyor --- */
function saveCloud(dataSave, counterSave) {
  console.log('[saveCloud] stub — no player');
}

/* --- Interstitial reklam --- */
function showFullscrenAd() {
  console.log('[showFullscrenAd] stub');
  if (window.unityInstance)
    window.unityInstance.SendMessage('SDKPlatform', 'OnPauseGame');
  setTimeout(function() {
    if (window.unityInstance)
      window.unityInstance.SendMessage('SDKPlatform', 'OnResumeGame');
  }, 300);
}

/* --- Odullu reklam --- */
function showRewardedAd(id) {
  console.log('[showRewardedAd] stub id=' + id);
  if (window.unityInstance) {
    window.unityInstance.SendMessage('SDKPlatform', 'OnPauseGame');
    setTimeout(function() {
      window.unityInstance.SendMessage('SDKPlatform', 'RewardComplete', id);
      setTimeout(function() {
        window.unityInstance.SendMessage('SDKPlatform', 'OnResumeGame');
      }, 100);
    }, 300);
  }
}

/* --- IAP stublari --- */
function checkShop()     { console.log('[checkShop] stub'); }
function initPurchasing(){ console.log('[initPurchasing] stub'); }
function buy(id_buy)     {
  console.log('[buy] stub id=' + id_buy);
  if (window.unityInstance)
    window.unityInstance.SendMessage('SDKPlatform', 'errorCallback', 1);
}
function rate() { /* bos */ }

/* ============================================================
   OYUNU YUKLE
   ============================================================ */
(async function () {
  try {
    /* 1) Data parcalarini indir, blob URL olustur */
    const dataUrl = await assembleDataBlob();

    /* 2) Config */
    const config = {
      dataUrl:            dataUrl,
      frameworkUrl:       FRAMEWORK_URL,
      codeUrl:            CODE_URL,
      streamingAssetsUrl: "StreamingAssets",
      companyName:        "GoGoMan",
      productName:        "Funny City Gopniks",
      productVersion:     "1.11",
    };

    /* 3) Loader'i yukle */
    loadingText.textContent = "Oyun yukleniyor...";
    await new Promise((res, rej) => {
      const s = document.createElement("script");
      s.src = LOADER_URL;
      s.onload  = res;
      s.onerror = () => rej(new Error("Loader yuklenemedi"));
      document.body.appendChild(s);
    });

    /* 4) Unity baslatma */
    progressBarEmpty.style.display = "";
    const inst = await createUnityInstance(canvas, config, (p) => {
      loadingText.textContent     = "";
      progressBarFull.style.width = Math.round(p * 100) + "%";
    });

    window.unityInstance = inst;
    loadingCover.style.display = "none";
    focusGame();

  } catch (err) {
    console.error(err);
    loadingText.textContent = "Hata: " + err.message;
  }
})();
</body>
</html>

</Content>
</Module>
