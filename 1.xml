    box-sizing: border-box;
    transition: transform 0.5s ease-in-out; 
  }

  /* Slide-out animation */
  #ad-container.hidden {
    transform: translate(-50%, -100%); /* Yukarı doğru gizlenir */
  }

  #ad-iframe {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 745px; 
    height: 90px; 
